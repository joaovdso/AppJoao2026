<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- FOTO -->
        <ImageView
            android:id="@+id/userProfileImageView"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="40dp"
            android:src="@mipmap/ic_default_user"
            android:scaleType="centerCrop"
            android:background="@drawable/circle_bg"
            android:clipToOutline="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/profileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Perfil do Usuário"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/userProfileImageView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp"
            app:layout_constraintTop_toBottomOf="@id/profileTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- NOME -->
                <EditText
                    android:id="@+id/registerNameEditText"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Nome"
                    android:padding="14dp"
                    android:background="@android:drawable/edit_text"/>

                <!-- EMAIL -->
                <EditText
                    android:id="@+id/registerEmailEditText"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:hint="Email"
                    android:padding="14dp"
                    android:background="@android:drawable/edit_text"/>

                <!-- TELEFONE -->
                <EditText
                    android:id="@+id/registerTelefoneEditText"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:hint="Telefone"
                    android:padding="14dp"
                    android:background="@android:drawable/edit_text"/>

                <!-- ENDEREÇO -->
                <EditText
                    android:id="@+id/registerEnderecoEditText"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:hint="Endereço"
                    android:padding="14dp"
                    android:background="@android:drawable/edit_text"/>

                <!-- SENHA -->
                <EditText
                    android:id="@+id/registerPasswordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:hint="Senha"
                    android:inputType="textPassword"
                    android:padding="14dp"
                    android:background="@android:drawable/edit_text"/>

                <!-- CONFIRMAR SENHA -->
                <EditText
                    android:id="@+id/registerConfirmPasswordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:hint="Confirmar Senha"
                    android:inputType="textPassword"
                    android:padding="14dp"
                    android:background="@android:drawable/edit_text"/>

                <!-- BOTÃO SALVAR -->
                <Button
                    android:id="@+id/salvarButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="SALVAR"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/button_gradient"/>

                <Button
                    android:id="@+id/sairButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="SAIR"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/button_gradient"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>